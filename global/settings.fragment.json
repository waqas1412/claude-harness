{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash",
      "WebFetch",
      "WebSearch",
      "Workflow"
    ],
    "deny": [
      "Bash(curl *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./*.pem)",
      "Read(./*.key)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "skipWorkflowUsageWarning": true,
  "_personalPrefs": {
    "_comment": "Keys under _personalPrefs are applied at top level by install.sh ONLY when run without --no-prefs. They are personal-global preferences, not portable defaults.",
    "model": "opus[1m]",
    "effortLevel": "xhigh",
    "theme": "dark",
    "tui": "fullscreen",
    "fallbackModel": ["sonnet"]
  }
}
