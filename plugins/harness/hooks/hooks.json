{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/block-coauthor.sh\"" },
          { "type": "command", "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/block-pr-reviewer.sh\"" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/block-md-emdash.sh\"" }
        ]
      }
    ]
  }
}
